// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator pothos {
  provider     = "prisma-pothos-types"
  output       = "../generated/pothos-types.ts"
  clientOutput = "./prisma/client"
  prismaUtils  = true
}

datasource db {
  provider = "postgresql"
}

model Team {
  id            String                @id @default(uuid())
  name          String                @unique
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  competitions  TeamsOnCompetitions[]
  playerHistory PlayerTeamHistory[]
  fixtures      Fixture[]
}

model Club {
  id        String    @id @default(uuid())
  name      String    @unique
  crest     Image?    @relation(name: "ClubCrest", fields: [crestId], references: [id], onDelete: SetNull)
  crestId   String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  fixtures  Fixture[]
}

model Competition {
  id        String                @id @default(uuid())
  name      String                @unique
  season    Season?               @relation(fields: [seasonId], references: [id])
  seasonId  String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  teams     TeamsOnCompetitions[]
  fixtures  Fixture[]
}

model Season {
  id           String        @id @default(uuid())
  name         String        @unique
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  competitions Competition[]
  fixtures     Fixture[]
}

model TeamsOnCompetitions {
  team          Team        @relation(fields: [teamId], references: [id])
  teamId        String
  competition   Competition @relation(fields: [competitionId], references: [id])
  competitionId String

  @@id([teamId, competitionId])
}

model Fixture {
  id            String       @id @default(uuid())
  name          String
  competition   Competition? @relation(fields: [competitionId], references: [id])
  competitionId String?
  season        Season?      @relation(fields: [seasonId], references: [id])
  seasonId      String?
  team          Team?        @relation(fields: [teamId], references: [id])
  teamId        String?
  opponent      Club?        @relation(fields: [opponentId], references: [id])
  opponentId    String?
  isHome        Boolean      @default(true)
  kickoff       DateTime
  venue         String
  scores        Score[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Player {
  id           String              @id @default(uuid())
  firstName    String
  lastName     String
  position     Position?           @relation(fields: [positionId], references: [id])
  positionId   String?
  bio          String?
  teamHistory  PlayerTeamHistory[]
  headshot     Image?              @relation(name: "PlayerHeadshot", fields: [headshotId], references: [id], onDelete: SetNull)
  headshotId   String?             @unique
  actionShot   Image?              @relation(name: "PlayerActionShot", fields: [actionShotId], references: [id], onDelete: SetNull)
  actionShotId String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  scores       Score[]
}

enum ScoreType {
  TRY
  CONVERSION
  PENALTY
  DROP_GOAL
}

model Score {
  id        String    @id @default(uuid())
  fixture   Fixture   @relation(fields: [fixtureId], references: [id])
  fixtureId String
  player    Player?   @relation(fields: [playerId], references: [id])
  playerId  String?
  type      ScoreType
  minute    Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Position {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  players   Player[]
}

model PlayerTeamHistory {
  id        String    @id @default(uuid())
  player    Player    @relation(fields: [playerId], references: [id])
  playerId  String
  team      Team      @relation(fields: [teamId], references: [id])
  teamId    String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Image {
  id           String   @id @default(uuid())
  url          String
  alt          String
  width        Int
  height       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  headshotOf   Player?  @relation("PlayerHeadshot")
  actionShotOf Player?  @relation("PlayerActionShot")
  crestOf      Club?    @relation("ClubCrest")
}
