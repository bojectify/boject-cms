model Season {
  id           String        @id @default(uuid())
  entryTitle   String        @default("")
  name         String        @unique
  slug         String        @unique
  startDate    DateTime
  endDate      DateTime
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  createdBy    String?
  updatedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  competitions Competition[]
  fixtures     Fixture[]
}
