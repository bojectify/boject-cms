model Image {
  id           String        @id @default(uuid())
  entryTitle   String        @default("")
  url          String
  alt          String
  width        Int
  height       Int
  storagePath  String?
  mimeType     String?
  fileSize     Int?
  originalName String?
  focalPointX  Float         @default(0.5)
  focalPointY  Float         @default(0.5)
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  createdBy    String?
  updatedBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  headshotOf   Player?       @relation("PlayerHeadshot")
  actionShotOf Player?       @relation("PlayerActionShot")
  crestOf      Club?         @relation("ClubCrest")
}
