model Player {
  id           String              @id @default(uuid())
  entryTitle   String              @default("")
  firstName    String
  lastName     String
  slug         String              @unique
  position     Position?           @relation(fields: [positionId], references: [id])
  positionId   String?
  bio          String?
  status       ContentStatus       @default(DRAFT)
  publishedAt  DateTime?
  createdBy    String?
  updatedBy    String?
  teamHistory  PlayerTeamHistory[]
  headshot     Image?              @relation(name: "PlayerHeadshot", fields: [headshotId], references: [id], onDelete: SetNull)
  headshotId   String?             @unique
  actionShot   Image?              @relation(name: "PlayerActionShot", fields: [actionShotId], references: [id], onDelete: SetNull)
  actionShotId String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  scores       Score[]
}

model Position {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  players   Player[]
}

model PlayerTeamHistory {
  id        String    @id @default(uuid())
  player    Player    @relation(fields: [playerId], references: [id])
  playerId  String
  team      Team      @relation(fields: [teamId], references: [id])
  teamId    String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
