{
  "name": "boject-cms-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "pnpm --filter cms dev",
    "build": "pnpm --filter cms build",
    "preview": "pnpm --filter cms preview",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev:registries:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:registries:down": "docker compose -f docker-compose.dev.yml down",
    "dev:publish:image": "pnpm dev:publish:image:as 0.0.1-rc.1",
    "dev:publish:image:as": "tsx scripts/dev-publish-image.ts",
    "dev:publish": "pnpm dev:publish:image && pnpm --filter create-boject-cms build && pnpm --filter @boject/cli build && (npm unpublish --registry http://localhost:4873 create-boject-cms@0.0.1-rc.1 --force 2>/dev/null || true) && (npm unpublish --registry http://localhost:4873 @boject/cli@0.0.1-rc.1 --force 2>/dev/null || true) && pnpm --filter create-boject-cms publish --no-git-checks && pnpm --filter @boject/cli publish --no-git-checks",
    "dev:scaffold": "tsx scripts/dev-scaffold.ts",
    "dev:verify": "tsx scripts/dev-verify.ts",
    "lint": "pnpm --filter cms lint",
    "lint:fix": "pnpm --filter cms lint:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter cms test:integration",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:e2e": "pnpm -r --if-present test:e2e",
    "typecheck": "pnpm --filter cms typecheck",
    "typecheck:scripts": "tsc --noEmit -p scripts/tsconfig.json",
    "prisma:generate": "pnpm --filter cms prisma:generate",
    "prisma:migrate": "pnpm --filter cms prisma:migrate",
    "prisma:seed": "pnpm --filter cms prisma:seed",
    "prisma:seed:test": "pnpm --filter cms prisma:seed:test",
    "prisma:studio": "pnpm --filter cms prisma:studio",
    "prisma:studio:test": "pnpm --filter cms prisma:studio:test",
    "apikey:create": "pnpm --filter cms apikey:create",
    "apikey:list": "pnpm --filter cms apikey:list",
    "apikey:revoke": "pnpm --filter cms apikey:revoke",
    "content:export": "pnpm --filter cms content:export",
    "content:import": "pnpm --filter cms content:import",
    "content:validate": "pnpm --filter cms content:validate",
    "starters:build": "pnpm --filter cms starters:build",
    "starters:check": "pnpm --filter cms starters:check",
    "storybook": "pnpm --filter cms storybook",
    "storybook:build": "pnpm --filter cms storybook:build"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
