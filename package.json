{
  "name": "boject-cms-workspace",
  "version": "0.0.1-rc.3",
  "license": "BUSL-1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "pnpm --filter cms dev",
    "build": "pnpm --filter cms build",
    "preview": "pnpm --filter cms preview",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "nuke:packages": "rm -rf node_modules apps/*/node_modules packages/*/node_modules perf/node_modules && pnpm install",
    "dev:registries:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:registries:down": "docker compose -f docker-compose.dev.yml down",
    "dev:publish:image": "pnpm dev:publish:image:as 0.0.1-rc.1",
    "dev:publish:image:as": "tsx scripts/dev-publish-image.ts",
    "dev:publish": "pnpm dev:publish:image && pnpm --filter create-boject-cms build && pnpm --filter @boject/cli build && (npm unpublish --registry http://localhost:4873 create-boject-cms@0.0.1-rc.1 --force 2>/dev/null || true) && (npm unpublish --registry http://localhost:4873 @boject/cli@0.0.1-rc.1 --force 2>/dev/null || true) && pnpm --filter create-boject-cms publish --registry http://localhost:4873 --no-git-checks && pnpm --filter @boject/cli publish --registry http://localhost:4873 --no-git-checks",
    "dev:scaffold": "tsx scripts/dev-scaffold.ts",
    "dev:verify": "tsx scripts/dev-verify.ts",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm -r test && pnpm test:scripts",
    "test:scripts": "vitest run --config scripts/vitest.config.ts",
    "test:cms": "pnpm --filter cms test",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:e2e": "pnpm -r --if-present test:e2e",
    "test:storybook": "pnpm -r --if-present test:storybook",
    "typecheck": "pnpm -r typecheck && tsc --noEmit -p scripts/tsconfig.json",
    "prisma:generate": "pnpm --filter cms prisma:generate",
    "prisma:migrate": "pnpm --filter cms prisma:migrate",
    "prisma:seed:test": "pnpm --filter cms prisma:seed:test",
    "prisma:seed:perf": "pnpm --filter cms prisma:seed:perf",
    "dev:bootstrap-admin": "pnpm --filter cms dev:bootstrap-admin",
    "prisma:studio": "pnpm --filter cms prisma:studio",
    "prisma:studio:test": "pnpm --filter cms prisma:studio:test",
    "prisma:studio:perf": "pnpm --filter cms prisma:studio:perf",
    "apikey:create": "pnpm --filter cms apikey:create",
    "apikey:list": "pnpm --filter cms apikey:list",
    "apikey:revoke": "pnpm --filter cms apikey:revoke",
    "search:reindex": "pnpm --filter cms search:reindex",
    "content:export": "pnpm --filter cms content:export",
    "content:import": "pnpm --filter cms content:import",
    "content:validate": "pnpm --filter cms content:validate",
    "starters:build": "pnpm --filter cms starters:build",
    "starters:check": "pnpm --filter cms starters:check",
    "storybook": "pnpm --filter cms storybook",
    "storybook:build": "pnpm --filter cms storybook:build",
    "perf:dev": "DATABASE_URL=postgresql://boject:boject@localhost:5432/boject_perf NITRO_HOST=0.0.0.0 pnpm --filter cms dev",
    "perf:seed": "pnpm --filter @boject/perf run seed",
    "perf:sweep": "pnpm --filter @boject/perf run sweep",
    "perf:report": "pnpm --filter @boject/perf run report",
    "perf:followups": "pnpm --filter @boject/perf run followups",
    "perf:scenario": "pnpm --filter @boject/perf run scenario",
    "create-boject-cms:build": "pnpm --filter create-boject-cms build",
    "create-boject-cms:start": "node packages/create-boject-cms/dist/index.js",
    "cli:build": "pnpm --filter @boject/cli build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
