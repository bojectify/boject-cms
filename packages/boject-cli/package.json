{
  "name": "@boject/cli",
  "version": "0.0.1-rc.1",
  "license": "BUSL-1.1",
  "private": false,
  "type": "module",
  "description": "Boject CMS maintenance CLI.",
  "author": "Boject Ltd",
  "homepage": "https://github.com/bojectify/boject-cms/tree/main/packages/boject-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bojectify/boject-cms.git",
    "directory": "packages/boject-cli"
  },
  "bugs": "https://github.com/bojectify/boject-cms/issues",
  "keywords": [
    "boject",
    "cms",
    "headless-cms",
    "cli",
    "content-management",
    "graphql"
  ],
  "bin": {
    "boject": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./perf": {
      "types": "./src/perf/index.ts",
      "default": "./dist/perf/index.js"
    },
    "./vendor/contentBundleTypes": "./dist/vendor/contentBundleTypes.ts",
    "./vendor/fieldTypes": "./dist/vendor/fieldTypes.ts",
    "./vendor/contentStatus": "./dist/vendor/contentStatus.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run --project integration"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "semver": "^7.6.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.11.10",
    "@types/semver": "^7.5.8",
    "msw": "^2.13.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
