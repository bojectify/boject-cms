# syntax=docker/dockerfile:1.7
# Dev container for boject-cms.
#
# Mirrors apps/cms/Dockerfile's base for prod-parity, then layers on:
#   - bash + git for interactive `dev` shells and lefthook
#   - build-base + python3 as node-gyp fallbacks
#   - chromium + fonts for Playwright (Storybook browser tests run headless here)
#
# Every `pnpm` and `pnpx` invocation on the dev machine routes into this
# container via the host shims at scripts/host-shims/. See spec
# docs/superpowers/specs/2026-05-14-dev-container-design.md (internal repo).

FROM node:24-alpine

# Shared corepack cache: prepare runs as root during image build, but the
# container runs as `node`. Without COREPACK_HOME pointing at a shared path,
# node's cache is empty and corepack prompts to re-download pnpm on first use.
ENV COREPACK_HOME=/opt/corepack

ARG PNPM_VERSION=11.1.2
RUN mkdir -p /opt/corepack \
 && corepack enable \
 && corepack prepare pnpm@${PNPM_VERSION} --activate \
 && chmod -R a+rX /opt/corepack

RUN apk add --no-cache \
      bash git \
      build-base python3 \
      chromium nss freetype harfbuzz ca-certificates ttf-freefont

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser \
    PNPM_STORE_PATH=/pnpm-store

USER node
WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]
