{
  "name": "boject-cms dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "eslint.workingDirectories": [
          { "pattern": "apps/*" },
          { "pattern": "packages/*" }
        ],
        "typescript.tsdk": "apps/cms/node_modules/typescript/lib"
      }
    }
  },
  "forwardPorts": [4000, 6006, 5555, 24678],
  "overrideCommand": false,
  "postCreateCommand": "pnpm install",
  "remoteUser": "node"
}
